# CSL Website — environment variables template
# Copy this file to .env.local and fill in real values for local development.
# Never commit .env.local to version control — it is covered by .gitignore.
# All variables below must also be set in Vercel > Project Settings > Environment Variables.

# ── Supabase ──────────────────────────────────────────────────────────────────

# Supabase project URL — Supabase Dashboard > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase public anon key — Supabase Dashboard > Project Settings > API > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key — Supabase Dashboard > Project Settings > API > service_role (SECRET: server-only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Stripe ────────────────────────────────────────────────────────────────────

# Stripe secret API key — Stripe Dashboard > Developers > API keys (use sk_test_ prefix until go-live sign-off)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Stripe webhook signing secret — Stripe Dashboard > Developers > Webhooks > select endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── Site URL ──────────────────────────────────────────────────────────────────

# Full public URL of the deployment — used as redirect base for Stripe Checkout and auth password-reset links
NEXT_PUBLIC_SITE_URL=https://csl-website-ten.vercel.app

# ── Resend (email — stubbed, implement when key is available) ─────────────────

# Resend API key — Resend Dashboard > API Keys > Create API key
RESEND_API_KEY=re_your-resend-api-key

# ── Zoho CRM (stubbed, implement when credentials are available) ──────────────

# Zoho OAuth client ID — Zoho API Console > EU data centre > your app > Client ID
ZOHO_CLIENT_ID=your-zoho-client-id

# Zoho OAuth client secret — Zoho API Console > EU data centre > your app > Client Secret
ZOHO_CLIENT_SECRET=your-zoho-client-secret

# Zoho access token — generated via Zoho OAuth flow using client ID + secret (expires; needs refresh logic)
ZOHO_ACCESS_TOKEN=your-zoho-access-token
