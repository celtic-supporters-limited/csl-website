    %% Deployment pipeline
    GH -->|"push to main triggers auto-deploy"| VCL

    %% User flows
    User -->|"browse public site"| PUB
    User -->|"sign in / sign up / reset"| AUTHPG
    User -->|"authenticated session"| PORTAL

    %% Auth interactions
    AUTHPG -->|"signInWithPassword\nsignInWithOtp\nsignUp · updateUser"| SAUTH
    MW -->|"getSession\nrefreshSession"| SAUTH
    ARST -->|"resetPasswordForEmail"| SAUTH

    %% API routes to Supabase DB
    ACHK -->|"read member by email"| TM
    AWBHK -->|"upsert member\nset status on event"| TM
    APROF -->|"update profile fields"| TM
    AST -->|"insert case"| TSC
    APX -->|"insert case"| TSC
    PORTAL -->|"read member · events\ndocuments · shareholder_cases"| SUPDB

    %% API routes to Stripe
    ACHK -->|"sessions.create"| STRCHK
    STRWBHK -->|"POST — signature verified"| AWBHK
    ABILL -->|"billingPortal.sessions.create"| STRBILL
    PORTAL -->|"charges.list\nsubscriptions.retrieve"| STRDATA

    %% Stubbed integrations (dashed)
    AST -.->|"fire-and-forget stub\n(lib/zoho.ts)"| ZOHO
    APX -.->|"fire-and-forget stub\n(lib/zoho.ts)"| ZOHO
    AWBHK -.->|"welcome email stub\n(lib/resend.ts)"| RESEND
    TEV -.->|"STUB_ file URLs\n(replace before go-live)"| GDRIVE
    TDC -.->|"STUB_ file URLs\n(replace before go-live)"| GDRIVE
