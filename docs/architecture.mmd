flowchart TD
    User(["User (Browser)"])
    GH["GitHub\ncelticsupporters-limited/csl-website\nmain branch"]

    subgraph VCL["Vercel — Next.js 14 App Router — csl-website-ten.vercel.app"]
        direction TB
        PUB["Public Pages\n/ · /membership · /share-tracing · /proxy\n/our-team · /faq · /celtic-paradox\n/privacy · /terms · /articles-of-association"]
