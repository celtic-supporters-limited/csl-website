        STRCHK["Checkout\n5 plans via dynamic price_data\nMonthly £10/£25/custom · Annual · Lifetime £5k"]
        STRWBHK["Webhook Events\nfired to /api/webhooks/stripe\n(STRIPE_WEBHOOK_SECRET verified)"]
        STRBILL["Billing Portal\nCard + subscription management"]
        STRDATA["charges.list\nsubscriptions.retrieve\n(live payment data for portal)"]
    end

    subgraph STUB["Stubbed — Future Integrations"]
        RESEND["Resend\nWelcome email on checkout.session.completed\nForm notifications to role mailboxes"]
