            ARST["POST /api/auth/reset-password\nTrigger Supabase reset email"]
        end
    end

    subgraph SUPA["Supabase — EU West (Ireland)"]
        SAUTH["Auth Service\nEmail+Password · Magic Link\nPKCE · JWT session cookies"]
